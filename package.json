{
  "name": "freepik-spaces-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server für Freepik Pikaso Spaces — steuert Nodes, Verbindungen und Workflows über Chrome DevTools Protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
